{
  "name": "undici-thread-interceptor",
  "version": "2.0.0",
  "description": "An Undici interceptor that routes requests over a worker thread",
  "author": "Matteo Collina <hello@matteocollina.com>",
  "homepage": "https://github.com/platformatic/undici-thread-interceptor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/platformatic/undici-thread-interceptor.git"
  },
  "keywords": [
    "undici",
    "agent",
    "thread",
    "worker"
  ],
  "bugs": {
    "url": "https://github.com/platformatic/undici-thread-interceptor/issues"
  },
  "private": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.base.json",
    "lint": "eslint --cache",
    "typecheck": "tsc -p . --noEmit",
    "format": "prettier -w src test",
    "bench": "node bench/bench.ts",
    "bench:compare": "node bench/compare.ts",
    "test": "c8 -c test/config/c8-local.json node --test --test-reporter=cleaner-spec-reporter 'test/*.test.ts' 'test/*/*.test.ts'",
    "test:ci": "node --test --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-lines=90 --test-coverage-branches=90 --test-coverage-functions=90 --test-reporter=cleaner-spec-reporter 'test/*.test.ts' 'test/*/*.test.ts'",
    "ci": "npm run build && npm run lint && npm run test:ci"
  },
  "dependencies": {
    "@watchable/unpromise": "^1.0.2",
    "fastq": "^1.20.1",
    "hyperid": "^4.0.0",
    "light-my-request": "^6.6.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/instrumentation-undici": "^0.29.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@platformatic/tsconfig": "^0.2.0",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "atomic-sleep": "^1.0.0",
    "c8": "^11.0.0",
    "cleaner-spec-reporter": "^1.0.3",
    "eslint": "^9.35.0",
    "express": "^5.2.1",
    "fastify": "^5.9.0",
    "koa": "^3.2.1",
    "neostandard": "^0.13.0",
    "prettier": "^3.9.4",
    "prettier-plugin-space-before-function-paren": "^0.1.0",
    "typescript": "^5.9.0",
    "ws": "^8.21.1"
  },
  "engines": {
    "node": ">= 22.22.0 || >= 24.6.0"
  }
}
